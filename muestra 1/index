<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cafetería Dulce Aroma</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif; }
    body { background:#fafafa; color:#333; }

    header {
      width:100%; background:#ffffffcc; backdrop-filter:blur(6px);
      position:fixed; top:0; left:0; z-index:1000;
      padding:20px 0; box-shadow:0 2px 8px #0002;
    }
    .header-container {
      width:90%; max-width:1100px; margin:auto;
      display:flex; justify-content:space-between; align-items:center;
    }
    nav a { margin-left:20px; text-decoration:none; color:#333; font-weight:bold; transition:.3s; }
    nav a:hover { color:#c49b63; }

    .hero {
      width:100%; height:90vh; background:url('https://picsum.photos/id/1060/1600/900') center/cover;
      display:flex; justify-content:center; align-items:center; text-align:center;
      padding:0 20px;
      margin-top:90px;
    }
    .hero h1 {
      font-size:3rem; color:white; text-shadow:0 4px 10px #000;
      animation:fadeInDown 1.2s ease;
    }

    @keyframes fadeInDown {
      0% {opacity:0; transform:translateY(-40px);} 
      100% {opacity:1; transform:translateY(0);} 
    }

    section { width:90%; max-width:1200px; margin:80px auto; }
    h2 { font-size:2.2rem; margin-bottom:20px; color:#333; }

    /* GRID PRODUCTOS */
    .productos-grid {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(220px,1fr));
      gap:25px;
    }
    .producto {
      background:white; border-radius:12px; box-shadow:0 4px 12px #0001;
      overflow:hidden; transition:.3s;
      animation:fadeIn .8s ease;
    }
    .producto:hover { transform:translateY(-6px); box-shadow:0 8px 18px #0003; }
    .producto img { width:100%; height:160px; object-fit:cover; }
    .producto-info { padding:15px; }
    .producto-info h3 { margin-bottom:10px; }
    .producto-info p { font-size:0.9rem; margin-bottom:8px; }
    .precio { font-weight:bold; color:#c49b63; font-size:1.1rem; }

    @keyframes fadeIn { from {opacity:0;} to {opacity:1;} }

    /* SECCIÓN SOBRE */
    .sobre {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
      gap:30px; align-items:center;
    }
    .sobre img { width:100%; border-radius:12px; box-shadow:0 4px 12px #0002; }
    .sobre p { font-size:1rem; line-height:1.6; }

    /* TESTIMONIOS */
    .testimonios-grid {
      display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:25px;
    }
    .card-testimonio {
      background:white; padding:20px; border-radius:12px; box-shadow:0 4px 12px #0001;
      animation:fadeIn .9s ease;
    }

    footer {
      background:#333; color:white; text-align:center;
      padding:35px 0; margin-top:90px;
    }
  </style>
</head>
<body>

  <header>
    <div class="header-container">
      <div class="logo"><strong>DulceAroma</strong></div>
      <nav>
        <a href="#productos">Productos</a>
        <a href="#sobre">Nosotros</a>
        <a href="#testimonios">Opiniones</a>
      </nav>
    </div>
  </header>

  <div class="hero">
    <h1>El café que te acompaña siempre ☕✨</h1>
  </div>

  <!-- SECCIÓN PRODUCTOS -->
  <section id="productos">
    <h2>Nuestros Productos</h2>
    <div class="productos-grid">

      <!-- 20+ PRODUCTOS -->
      <!-- Usamos misma foto pero puedes cambiar cuando quieras -->
      <script>
        const productos = [
          "Capuccino Clásico","Latte Vainilla","Mocha Chocolate","Café Americano","Flat White",
          "Espresso Doble","Café Caramelo","Latte Avellana","Latte Chocolate Blanco","Mocaccino",
          "Té Chai Latte","Matcha Latte","Smoothie Frutilla","Smoothie Mango","Limonada Jengibre",
          "Cheesecake Frutilla","Brownie Chocolate","Galleta Chips","Croissant Mantequilla","Roll Canela",
          "Sandwich Pollo","Sandwich Veggie","Ensalada César","Bagel Clásico","Panini Queso"
        ];
        document.addEventListener("DOMContentLoaded",()=>{
          const grid=document.querySelector('.productos-grid');
          productos.forEach(p=>{
            grid.innerHTML+=`
              <div class="producto">
                <img src="https://picsum.photos/400/300?random=${Math.floor(Math.random()*50)}" />
                <div class="producto-info">
                  <h3>${p}</h3>
                  <p>Un clásico favorito de la casa, preparado con ingredientes frescos.</p>
                  <span class="precio">$3.500 CLP</span>
                </div>
              </div>`;
          });
        });
      </script>

    </div>
  </section>

  <!-- SOBRE NOSOTROS -->
  <section id="sobre">
    <h2>Sobre Nosotros</h2>
    <div class="sobre">
      <img src="https://picsum.photos/id/1080/600/400" alt="Cafetería" />
      <p>
        Somos una cafetería dedicada a entregar experiencias cálidas y auténticas.
        Nuestro café es seleccionado de pequeños productores y cada preparación
        está hecha con cariño para acompañarte en tu día.
        <br><br>
        Además contamos con un ambiente tranquilo, ideal para estudiar, trabajar
        o simplemente relajarte.
      </p>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section id="testimonios">
    <h2>Opiniones de Clientes</h2>
    <div class="testimonios-grid">
      <div class="card-testimonio">“El mejor latte que he probado, suave y delicioso.” — Camila</div>
      <div class="card-testimonio">“Lugar tranquilo, perfecto para venir con amigos o trabajar.” — Jorge</div>
      <div class="card-testimonio">“Los pasteles son una locura, especialmente el cheesecake.” — Fernanda</div>
    </div>
  </section>

  <footer>
    © 2025 DulceAroma — Todos los derechos reservados
  </footer>

</body>
</html>
