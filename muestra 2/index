      padding:14px 6%;
      display:flex;align-items:center;justify-content:space-between;gap:12px;
      border-bottom:1px solid rgba(255,255,255,0.03);
    }
    .nav .brand{font-weight:900;color:#00ff88;letter-spacing:1px;font-size:20px}
    .nav .menu{display:flex;align-items:center;gap:18px}
    .nav .menu a{color:#ddd;font-weight:600;font-size:14px;padding:8px;border-radius:8px}
    .nav .menu a:hover{color:#000;background:#00ff88}
    .nav .cta{margin-left:12px;background:#00ff88;color:#000;padding:8px 14px;border-radius:8px;font-weight:700}

